# ═══════════════════════════════════════════════════════════════════════
# Analytics Chatbot POC — Backend Environment Variables
# Copy this file to backend/.env and fill in your values
# ═══════════════════════════════════════════════════════════════════════

# ── GCP Project ─────────────────────────────────────────────────────
GCP_PROJECT_ID=your-project-id

# ── BigQuery Dataset (where user_access table + views live) ─────────
BQ_DATASET=rbac_demo

# ── Google OAuth Client ID (from GCP Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com

# ── Vertex AI / Gemini ──────────────────────────────────────────────
VERTEX_AI_LOCATION=us-central1
GEMINI_FLASH_MODEL=gemini-1.5-flash-001
GEMINI_PRO_MODEL=gemini-1.5-pro-001

# ── Frontend URL (for CORS) ────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
