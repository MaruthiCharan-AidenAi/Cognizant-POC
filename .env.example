# ═══════════════════════════════════════════════════════════════════════
# Analytics Chatbot — Backend environment
# Copy to backend/.env and fill in values (backend/.env is gitignored).
# ═══════════════════════════════════════════════════════════════════════

# ── GCP Project ─────────────────────────────────────────────────────
GCP_PROJECT_ID=your-project-id

# ── BigQuery ────────────────────────────────────────────────────────
BQ_DATASET=cognizant_poc
BQ_MAIN_TABLE=bqdata
BQ_CHAT_SESSIONS_TABLE=chat_sessions
BQ_CHAT_MESSAGES_TABLE=chat_messages

# ── Google OAuth (Console → APIs & Services → Credentials → OAuth client)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── Vertex AI / Gemini ──────────────────────────────────────────────
VERTEX_AI_LOCATION=us-central1
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-flash

# Embeddings for Vector Search (index dimension must match model; gemini-embedding-001 = 3072)
VERTEX_EMBEDDING_MODEL=gemini-embedding-001
# Optional down-projection for compatibility with existing 768-dim indexes.
VERTEX_EMBEDDING_DIMENSIONS=768

# ── Vertex AI Vector Search (optional) ───────────────────────────────
# Get these from Google Cloud Console → Vertex AI → Vector Search (steps in backend docs).
# Use the SAME region as VERTEX_AI_LOCATION (e.g. us-central1).
VERTEX_VECTOR_SEARCH_INDEX_ID=
VERTEX_VECTOR_SEARCH_INDEX_ENDPOINT_ID=
VERTEX_VECTOR_SEARCH_DEPLOYED_INDEX_ID=

# ── Chat ───────────────────────────────────────────────────────────
CHAT_HISTORY_MAX_TURNS=24
CHAT_RETRIEVAL_MAX_NEIGHBORS=5

# ── Frontend URL (CORS) ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
